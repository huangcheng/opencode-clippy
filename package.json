{
  "name": "opencode-clippy-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "A Microsoft Office Clippy desktop widget that hooks into OpenCode events — animations, proactive tips, and Lottie effects",
  "repository": {
    "type": "git",
    "url": "https://github.com/huangcheng/opencode-clippy.git"
  },
  "author": {
    "name": "HUANG Cheng",
    "email": "cheng@duck.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm --filter @opencode-clippy/shared build && pnpm --filter opencode-clippy build && pnpm --filter @opencode-clippy/desktop build",
    "build:plugin": "pnpm --filter opencode-clippy build",
    "build:desktop": "pnpm --filter @opencode-clippy/desktop build",
    "dev": "pnpm --filter @opencode-clippy/desktop dev",
    "package": "pnpm --filter @opencode-clippy/desktop package",
    "package:mac": "pnpm --filter @opencode-clippy/desktop package:mac",
    "package:win": "pnpm --filter @opencode-clippy/desktop package:win",
    "package:linux": "pnpm --filter @opencode-clippy/desktop package:linux",
    "start": "pnpm --filter @opencode-clippy/desktop start"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
