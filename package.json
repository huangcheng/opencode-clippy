{
  "name": "opencode-clippy",
  "version": "0.1.0",
  "description": "A Microsoft Office Clippy desktop widget that hooks into OpenCode events",
  "main": "dist/widget/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"vite build --watch\"",
    "start": "electron dist/widget/main/main.js",
    "clippy": "npm run build && electron dist/widget/main/main.js",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@opencode-ai/plugin": "^1.4.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "lottie-web": "^5.12.0",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.opencode.clippy",
    "productName": "OpenCode Clippy",
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  }
}
