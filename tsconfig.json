{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "lib": ["ES2022"]
  },
  "include": ["plugin/**/*.ts", "widget/**/*.ts", ".opencode/plugins/**/*.ts"],
  "exclude": ["node_modules", "dist", "widget/renderer/**/*.ts"]
}
